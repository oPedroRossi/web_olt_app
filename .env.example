# App
APP_HOST=127.0.0.1
APP_PORT=5169
FLASK_DEBUG=false
LOG_LEVEL=INFO

# Huawei OLT credentials
OLT_USERNAME=<OLT_USERNAME>
OLT_PASSWORD=<OLT_PASSWORD>
OLT_PORT=22

# Optional: netmiko transcript for troubleshooting
NETMIKO_SESSION_LOG=netmiko-session.log

# Allowed OLT list rendered in UI (JSON array)
# Replace placeholders with real management IPs in local .env
OLT_OPTIONS=[{"name":"OLT_A","ip":"<OLT_IP_1>"},{"name":"OLT_B","ip":"<OLT_IP_2>"}]
